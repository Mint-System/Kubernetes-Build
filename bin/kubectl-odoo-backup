#!/usr/bin/env bash
set -e

script=$(basename "$0")
version="1.0.1"

help() {
    echo
    echo "$script v$version"
    echo
    echo 'Description: Backup Odoo database in Kubernetes cluster.'
    echo "Syntax: $script <label> <database>"
    echo "Example: $script odoo odoo"
    echo 'Options:'
    echo "  help  Show $script manual."
    echo
}

if [[ "$1" == 'help' ]]; then
    help
    exit 0
fi

label="$1"
database="$2"

[[ -z "$label" ]] && { echo 'Error: Parameter label is empty'; exit 1; }
[[ -z "$database" ]] && { echo 'Error: Parameter database is empty'; exit 1; }

pod_id=$(kubectl get pods -l app="$label" -o jsonpath='{.items[0].metadata.name}' 2>/dev/null)

if [[ -z "$pod_id" ]]; then
    echo "Error: No pod found with label '$label'"
    exit 1
fi

kubectl_exec="kubectl exec $pod_id -- /bin/bash -c"

echo "Backup database $database to /var/lib/odoo/$database.tar..."

echo 'Dump database.'
$kubectl_exec "pg_dump '$database' > /var/lib/odoo/dump.sql"
$kubectl_exec "ls -lsh /var/lib/odoo/dump.sql"

echo "Tar filestore and dump to /var/lib/odoo/$database.tar."
$kubectl_exec "tar -cf /var/lib/odoo/$database.tar -C /var/lib/odoo dump.sql filestore/$database"

echo 'Remove dump.'
$kubectl_exec "rm -rf /var/lib/odoo/dump.sql"

echo "The Odoo backup has finished: /var/lib/odoo/$database.tar"